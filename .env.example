# ─── Payload CMS ─────────────────────────────────────────────
# Long random string. Generate with: openssl rand -base64 32
PAYLOAD_SECRET=replace-me-with-32-byte-secret

# Public URL — used by Payload for absolute admin links + emails.
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# ─── Database (Neon Postgres) ────────────────────────────────
# Get from https://neon.tech — free tier is fine for dev.
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# ─── Site ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── GoHighLevel (filled in by Faiz) ─────────────────────────
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WEBHOOK_SECRET=

# ─── Stripe (added in Week 6) ────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Resend transactional email ──────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@silverlineind.com

# ─── Mapbox (service area isochrone) ─────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Calendly (scheduling embed on /contact) ─────────────────
NEXT_PUBLIC_CALENDLY_URL=

# ─── Analytics ───────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_CLARITY_ID=
